# ============================================================
# 念念（NianNian）环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env
# ============================================================

# DeepSeek API Key（对话模型，必填）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 阿里云 DashScope API Key（Embedding 向量化模型，必填）
# 获取地址：https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# Tavily API Key（联网搜索，可选，不填则禁用联网搜索）
# 获取地址：https://tavily.com/
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# 高德地图 API Key（天气/位置服务，可选，不填则禁用天气功能）
# 获取地址：https://lbs.amap.com/
AMAP_API_KEY=your-amap-api-key-here